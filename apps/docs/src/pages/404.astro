---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | convex-inspect</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #171622;
        --panel: rgba(27, 27, 39, 0.9);
        --line: rgba(237, 240, 255, 0.12);
        --text: #edf0ff;
        --muted: #a7acc6;
        --accent: #60a5fa;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          radial-gradient(circle at top left, rgba(141, 38, 118, 0.24), transparent 28%),
          radial-gradient(circle at top right, rgba(238, 52, 47, 0.18), transparent 24%),
          linear-gradient(180deg, #211f31 0%, #171622 56%, #14131c 100%);
        color: var(--text);
        font-family: "IBM Plex Mono", "SFMono-Regular", "Menlo", monospace;
      }

      main {
        width: min(560px, 100%);
        padding: 32px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background: var(--panel);
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.28);
      }

      p {
        color: var(--muted);
        line-height: 1.7;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Page Not Found</h1>
      <p>The page you requested does not exist or has moved.</p>
      <p><a href="/convex-inspect/">Back to the docs</a></p>
    </main>
  </body>
</html>
